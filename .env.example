# AgentMesh environment variables
# Copy this file to .env and fill in your values

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Groq API key for Llama 3.3 70B (free tier available at console.groq.com)
# Only needed by the example agents (DataAgent, CodeAgent, WriterAgent, ResearchAgent).
# The core mesh (registry, router, SDK) has no LLM dependency.
GROQ_API_KEY=gsk_your_key_here

# ---------------------------------------------------------------------------
# Optional -- infrastructure
# ---------------------------------------------------------------------------

# PostgreSQL connection string (falls back to in-memory if not set)
DATABASE_URL=postgresql://mesh:meshpass@localhost:5432/agentmesh

# Redis connection string (used by AgentMemory for cross-agent session state)
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Optional -- networking
# ---------------------------------------------------------------------------

# URL of the mesh registry (used by SDK agents and CLI)
REGISTRY_URL=http://localhost:8080

# Port the registry listens on
REGISTRY_PORT=8080

# ---------------------------------------------------------------------------
# Optional -- security
# ---------------------------------------------------------------------------

# JWT signing secret -- enables auth enforcement on register/deregister/trust/memory endpoints.
# If unset, the registry runs in dev mode (all endpoints open, anonymous callers accepted).
AGENT_SECRET=change-me-in-production

# ---------------------------------------------------------------------------
# Optional -- safety
# ---------------------------------------------------------------------------

# Allowed base directory for csv_path in DataAgent (path traversal protection).
# csv_path values outside this directory are rejected with HTTP 400.
CSV_SAFE_DIR=/data/uploads

# ---------------------------------------------------------------------------
# Optional -- logging
# ---------------------------------------------------------------------------

# Python log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
