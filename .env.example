# AgentMesh environment variables
# Copy this file to .env and fill in your values

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Groq API key for Llama 3.3 70B (free tier available at console.groq.com)
GROQ_API_KEY=gsk_your_key_here

# ---------------------------------------------------------------------------
# Optional -- infrastructure
# ---------------------------------------------------------------------------

# PostgreSQL connection string (falls back to in-memory if not set)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://mesh:meshpass@localhost:5432/agentmesh

# Redis connection string (not yet used, reserved for future pub/sub)
REDIS_URL=redis://localhost:6379

# ---------------------------------------------------------------------------
# Optional -- networking
# ---------------------------------------------------------------------------

# URL of the mesh registry (used by SDK agents and CLI)
REGISTRY_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Optional -- logging
# ---------------------------------------------------------------------------

# Python log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
